

local repo = 'https://raw.githubusercontent.com/violin-suzutsuki/LinoriaLib/main/'
local Library = loadstring(game:HttpGet(repo .. 'Library.lua'))()

local GAMES = {
    [286090429] = { -- Arsenal
        name = 'Arsenal',
        url = 'https://api.jnkie.com/api/v1/luascripts/public/3dc9eabb17c055d6d59c648a8010c49476f2ddd7ae83a6be580ba0d43fc76f09/download',
        close = true, -- close the loader before running
    },
    [142823291] = { -- Murder Mystery 2
        name = 'Murder Mystery 2',
        url = 'https://api.jnkie.com/api/v1/luascripts/public/7280f74cf8e6a8974b97dcc496855647fb16556b685618050edd901f08991fbf/download',
        close = false, -- keep the loader open
    },
}

local current = GAMES[game.PlaceId]

local Window = Library:CreateWindow({
    Title = 'Loader',
    Center = true,
    AutoShow = true,
    TabPadding = 8,
    MenuFadeTime = 0.2,
})

local Tab = Window:AddTab('Main')
local Box = Tab:AddLeftGroupbox('Script')

local keyValue = 'KEYLESS'

local function runScript(target)
    getgenv().script_key = keyValue
    getgenv().SCRIPT_KEY = keyValue
    if target.close then
        Library:Unload()
    end
    local ok, err = pcall(function()
        loadstring(game:HttpGet(target.url))()
    end)
    if not ok then
        warn('[Loader] Failed to run ' .. target.name .. ' script: ' .. tostring(err))
        if not target.close then
            Library:Notify('Failed to run ' .. target.name .. ' script', 5)
        end
    end
end

if current then
    Box:AddLabel('Detected: ' .. current.name)
    -- user clicks this to inject/run the script
    Box:AddButton('Load ' .. current.name, function()
        runScript(current)
    end)
else
    Box:AddLabel('This game is not supported.')
    Library:Notify('Loader: unsupported game (PlaceId ' .. tostring(game.PlaceId) .. ')', 5)
end
